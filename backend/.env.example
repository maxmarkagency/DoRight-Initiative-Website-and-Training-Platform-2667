# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server Configuration
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Configuration (Supabase handles this, but kept for compatibility)
JWT_SECRET=your_supabase_jwt_secret
JWT_REFRESH_SECRET=your_supabase_jwt_secret

# Email Configuration (Optional - Supabase handles auth emails)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@doright.ng

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=doright-lms-media

# Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Site Settings
SITE_NAME=DoRight Academy
SITE_URL=https://academy.doright.ng
ADMIN_EMAIL=admin@doright.ng

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=100MB
ALLOWED_FILE_TYPES=mp4,avi,mov,pdf,doc,docx,ppt,pptx,jpg,jpeg,png,gif

# Certificate Generation
CERTIFICATE_TEMPLATE_PATH=./templates/certificate.html
CERTIFICATE_SIGNATURE_KEY=your_certificate_signing_key